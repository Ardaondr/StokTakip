<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:StokTakip.Models"
        x:Class="StokTakip.MainWindow"
        Title="Stok Takip Paneli" Width="1100" Height="750" MinWidth="950" MinHeight="600"
        Background="#F4F6F8">
    
    <Grid ColumnDefinitions="240,*">
        
        <!-- ================= SOL KENAR ÇUBUĞU (SIDEBAR) ================= -->
        <Border Grid.Column="0" Background="#1A1C23" Padding="20">
            <Grid RowDefinitions="Auto,*,Auto">
                
                <!-- Logo / Başlık Bölümü -->
                <StackPanel Grid.Row="0" Margin="0,10,0,40" Spacing="4">
                    <TextBlock Text="STOK.IO" FontSize="20" FontWeight="Black" Foreground="White" LetterSpacing="1.5"/>
                    <TextBlock Text="Özelleştirilmiş Stok Takip Sistemi" FontSize="11" Foreground="#6B7280" FontWeight="Medium"/>
                </StackPanel>
                
                <!-- Tıklanabilir Menü Butonları -->
                <StackPanel Grid.Row="1" Spacing="6">
                    <!-- ÜRÜN YÖNETİMİ ANA GRUBU -->
                    <Button Name="BtnUrunYonetimi" Click="Menu_Click" Tag="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="#2D3142" Foreground="White" CornerRadius="8" Padding="12,10" Margin="0,0,0,2">
                        <TextBlock Text="📦 Ürün Yönetimi" FontWeight="SemiBold" FontSize="13"/>
                    </Button>
                    
                    <Button Name="BtnLoglar" Click="Menu_Click" Tag="3" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#9CA3AF" CornerRadius="6" Padding="20,8" Margin="0,0,0,15">
                        <TextBlock Text="• Sistem Logları" FontWeight="Medium" FontSize="12"/>
                    </Button>
                    
                    <!-- SİSTEM AYARLARI ANA GRUBU -->
                    <TextBlock Text="⚙️ SİSTEM AYARLARI" FontSize="11" FontWeight="Bold" Foreground="#4B5563" Margin="12,0,0,6" LetterSpacing="1"/>
                    
                    <!-- Veri Kontrolü -->
                    <Button Name="BtnYedekleme" Click="Menu_Click" Tag="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#9CA3AF" CornerRadius="6" Padding="20,8">
                        <TextBlock Text="• Veri Kontrolü" FontWeight="Medium" FontSize="12"/>
                    </Button>
                    <Button Name="BtnYetkiler" Click="Menu_Click" Tag="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#9CA3AF" CornerRadius="6" Padding="20,8">
                        <TextBlock Text="• Kullanıcı Değiştir / Ekle" FontWeight="Medium" FontSize="12"/>
                    </Button>
                    <Button Name="BtnLisans" Click="Menu_Click" Tag="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#9CA3AF" CornerRadius="6" Padding="20,8">
                        <TextBlock Text="• Hakkında" FontWeight="Medium" FontSize="12"/>
                    </Button>
                </StackPanel>
                
                <!-- Sol Alt Kullanıcı Seçim Alanı -->
                <StackPanel Grid.Row="2" Spacing="8" Margin="0,0,0,10">
                    <TextBlock Text="👤 Aktif Kullanıcı:" FontSize="11" Foreground="#6B7280" FontWeight="Bold"/>
                    <ComboBox Name="UserComboBox" HorizontalAlignment="Stretch" Background="#2D3142" Foreground="White" CornerRadius="6">
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= SAĞ İÇERİK ALANI ================= -->
        <TabControl Name="MainTabControl" Grid.Column="1" BorderThickness="0" Margin="0" Padding="0">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="IsVisible" Value="False"/>
                </Style>
            </TabControl.Styles>

            <!-- SEKME 0: ÜRÜN YÖNETİMİ -->
            <TabItem>
                <Grid RowDefinitions="Auto,*,Auto" Margin="24">
                    
                    <!-- Form ve Arama Alanlarını İçeren Üst Panel -->
                    <StackPanel Grid.Row="0" Spacing="12" Margin="0,0,0,20">
                        
                        <!-- KATMAN 1: Geniş ve Ferah Arama Motoru -->
                        <Border Background="White" CornerRadius="12" Padding="14,12" BorderBrush="#E5E7EB" BorderThickness="1">
                            <TextBox x:Name="SearchBox" Watermark="🔎 Listede hızlı ara" 
                                     Background="#F9FAFB" BorderBrush="#E5E7EB" Height="40" CornerRadius="6" 
                                     FontSize="13" TextChanged="SearchBox_TextChanged"/>
                        </Border>
                        
                        <!-- KATMAN 2: Veri Giriş ve Operasyon Butonları -->
                        <Border Background="White" CornerRadius="12" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1">
                            <Grid ColumnDefinitions="*,150,Auto">
                                <!-- Giriş kutularının geniş paylaşımı -->
                                <Grid Grid.Column="0" ColumnDefinitions="*,130" Margin="0,0,12,0">
                                    <AutoCompleteBox x:Name="NameBox" Grid.Column="0" Watermark="İlaç Adı Girin" FilterMode="Contains" Height="38" Margin="0,0,10,0"/>
                                    <TextBox x:Name="QuantityBox" Grid.Column="1" Watermark="Sayı Girin" Background="#F9FAFB" BorderBrush="#E5E7EB" Height="38" CornerRadius="6"/>
                                </Grid>

                                <!-- Hızlı Stok Değişim Butonları (-1 ve +1) -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="0,0,16,0">
                                    <Button Content="-1" Width="44" Height="38" Background="#3B82F6" Foreground="White" FontWeight="Bold" CornerRadius="6" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="FastDecreaseButton_Click"/>
                                    <Button Content="+1" Width="44" Height="38" Background="#3B82F6" Foreground="White" FontWeight="Bold" CornerRadius="6" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="FastIncreaseButton_Click"/>
                                </StackPanel>
                                
                                <!-- Standart Yönetim Butonları -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="AddButton" Content="Ekle" Width="65" Height="38" Background="#10B981" Foreground="White" FontWeight="SemiBold" CornerRadius="6" HorizontalContentAlignment="Center" Click="AddButton_Click"/>
                                    <Button x:Name="UpdateButton" Content="Güncelle" Width="85" Height="38" Background="#F59E0B" Foreground="White" FontWeight="SemiBold" CornerRadius="6" HorizontalContentAlignment="Center" Click="UpdateButton_Click"/>
                                    <Button x:Name="DeleteButton" Content="Sil" Width="55" Height="38" Background="#EF4444" Foreground="White" FontWeight="SemiBold" CornerRadius="6" HorizontalContentAlignment="Center" Click="DeleteButton_Click"/>
                                    <Button x:Name="ClearButton" Content="Temizle" Width="80" Height="38" Background="#6B7280" Foreground="White" FontWeight="SemiBold" CornerRadius="6" HorizontalContentAlignment="Center" Click="ClearButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Stok Tablosu -->
                    <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="4" Margin="0,0,0,20" BorderBrush="#E5E7EB" BorderThickness="1">
                        <DataGrid x:Name="ProductGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="ProductGrid_SelectionChanged" x:DataType="models:Product" Background="Transparent" RowBackground="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="İlaç Adı" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Miktar" Binding="{Binding Quantity}" Width="130"/>
                                <DataGridTextColumn Header="Son Güncelleme" Binding="{Binding LastUpdated, StringFormat={}{0:g}}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Durum Mesajı + Sayfalama (Pager) -->
                    <Grid Grid.Row="2" Margin="4,0,0,0" ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="StatusText" Grid.Column="0" FontWeight="Medium" FontSize="13" Foreground="#EF4444" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Button x:Name="PrevPageButton" Content="◀ Önceki" Padding="12,6" Background="#E5E7EB" Foreground="#374151" CornerRadius="6" FontWeight="SemiBold" Click="PrevPageButton_Click"/>
                            <TextBlock x:Name="PageInfoText" VerticalAlignment="Center" FontSize="13" Foreground="#374151" FontWeight="Medium"/>
                            <Button x:Name="NextPageButton" Content="Sonraki ▶" Padding="12,6" Background="#E5E7EB" Foreground="#374151" CornerRadius="6" FontWeight="SemiBold" Click="NextPageButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- SEKME 1: VERİ KONTROLÜ -->
            <TabItem>
                <Grid Margin="40" RowDefinitions="Auto,Auto,*">
                    <TextBlock Grid.Row="0" Text="📊 Veri Kontrolü ve Entegrasyon" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Grid.Row="1" Text="Mevcut stok listelerinizi dışa aktarın, şablonları indirin veya Excel transferlerinizi gerçekleştirin." FontSize="13" Foreground="#6B7280" Margin="0,4,0,30"/>
                    
                    <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E5E7EB" BorderThickness="1" VerticalAlignment="Top">
                        <StackPanel Spacing="16">
                            <Button Content="🖨️ Güncel Stok Durumunu Raporla (PDF/TXT)" Padding="16,14" Background="#374151" Foreground="White" CornerRadius="6" FontWeight="SemiBold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="PrintReportButton_Click"/>
                            
                            <Button Content="📝 Örnek Excel Yükleme Şablonu İndir" Padding="16,14" Background="#4B5563" Foreground="White" CornerRadius="6" FontWeight="SemiBold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="DownloadTemplateButton_Click"/>
                            
                            <Separator BorderBrush="#E5E7EB" BorderThickness="0.5" Margin="0,5"/>
                            
                            <Button Content="📥 Excel Dosyasından Veri İçe Aktar" Padding="16,14" Background="#10B981" Foreground="White" CornerRadius="6" FontWeight="SemiBold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="ImportExcelButton_Click"/>
                            <Button Content="📤 Mevcut Stoğu Excel Olarak Dışa Aktar" Padding="16,14" Background="#3B82F6" Foreground="White" CornerRadius="6" FontWeight="SemiBold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="ExportExcelButton_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- SEKME 2: KULLANICI EKLEME VE YÖNETME EKRANI -->
            <TabItem>
                <Grid Margin="40" RowDefinitions="Auto,Auto,*">
                    <TextBlock Grid.Row="0" Text="👥 Kullanıcı Tanımlama" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Grid.Row="1" Text="Sistemde işlem yapacak kişilerin isimlerini ekleyin veya listeden kaldırın." FontSize="13" Foreground="#6B7280" Margin="0,4,0,30"/>
                    
                    <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E5E7EB" BorderThickness="1" VerticalAlignment="Top">
                        <Grid RowDefinitions="Auto,Auto,*,Auto">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                                <TextBox Name="NewUserBox" Watermark="Eklenecek personel ismi yazın..." Height="38" Margin="0,0,12,0"/>
                                <Button Content="Kullanıcı Ekle" Grid.Column="1" Height="38" Background="#10B981" Foreground="White" CornerRadius="6" Padding="15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="AddUserButton_Click"/>                            </Grid>
                            
                            <TextBlock Grid.Row="1" Text="Sistemde Kayıtlı İsimler" FontWeight="Bold" Margin="0,0,0,10"/>
                            
                            <ListBox Name="UsersListBox" Grid.Row="2" Background="#F9FAFB" CornerRadius="8" Height="220" Margin="0,0,0,16">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Padding="5" FontSize="13"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Button Name="DeleteUserButton" Grid.Row="3" Content="🗑️ Seçili Kullanıcıyı Sistemden Sil" Background="#EF4444" Foreground="White" FontWeight="SemiBold" CornerRadius="6" Height="38" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="DeleteUserButton_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- SEKME 3: TAM SAYFA LOG BÖLÜMÜ -->
            <TabItem>
                <Grid Margin="40" RowDefinitions="Auto,Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <TextBlock Text="📋 Sistem İşlem Günlükleri" FontSize="22" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="🗑️ Log Geçmişini Temizle" FontSize="12" Padding="14,8" Background="#EF4444" Foreground="White" CornerRadius="6" FontWeight="SemiBold" Click="ClearLogsButton_Click"/>
                    </Grid>
                    <TextBlock Grid.Row="1" Text="Depoda gerçekleştirilen ekleme, silme ve güncelleme hareketlerinin kronolojik dökümü." FontSize="13" Foreground="#6B7280" Margin="0,4,0,25"/>
                    
                    <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="4" BorderBrush="#E5E7EB" BorderThickness="1">
                        <DataGrid x:Name="LogGrid" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" RowBackground="White" x:DataType="models:StockLog">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Zaman" Binding="{Binding Timestamp, StringFormat={}{0:dd.MM HH:mm}}" Width="125"/>
                                <DataGridTextColumn Header="Kullanıcı" Binding="{Binding Operator}" Width="150" Foreground="#10B981" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="İşlem Türü" Binding="{Binding ActionType}" Width="120" Foreground="#3B82F6" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Etkilenen İlaç" Binding="{Binding ProductName}" Width="200"/>
                                <DataGridTextColumn Header="İşlem Açıklaması ve Detay" Binding="{Binding Details}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- SEKME 4: HAKKINDA BÖLÜMÜ -->
            <TabItem>
                <Grid Margin="40" RowDefinitions="Auto,Auto,*">
                    <TextBlock Grid.Row="0" Text="📝 Hakkında" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Grid.Row="1" Text="STOK.IO Özelleştirilmiş Stok Takip Sistemi kaynak kodu ve mimari detayları." FontSize="13" Foreground="#6B7280" Margin="0,4,0,25"/>
                    
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Border Background="White" CornerRadius="12" Padding="24" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel Spacing="18">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="📌 Ne işe yarar?" FontSize="15" FontWeight="Bold" Foreground="#1F2937"/>
                                    <TextBlock Text="Bu çalışma; zirai ilaç bayileri ve depoları için geliştirilmiş modern ve hafif bir stok yönetim panelidir. Kullanıcıyı yormayan minimalist bir arayüzle depo hareketlerini anlık olarak kontrol etmeyi amaçlar." 
                                               TextWrapping="Wrap" Foreground="#4B5563" FontSize="13" LineHeight="20"/>
                                </StackPanel>

                                <Separator BorderBrush="#E5E7EB" BorderThickness="0.5"/>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="🛠️ Teknolojik Altyapı " FontSize="15" FontWeight="Bold" Foreground="#1F2937"/>
                                    <TextBlock Text="• Framework: .NET 8.0 &amp; Avalonia UI (Cross-Platform Mac/Windows/Linux)" Foreground="#4B5563" FontSize="13"/>
                                    <TextBlock Text="• Veritabanı Ortamı: Entity Framework Core &amp; SQLite Mimarisi" Foreground="#4B5563" FontSize="13"/>
                                    <TextBlock Text="• Mimari Yapı: Modern Single-Window, Tab-Driven Dashboard Mimarisi" Foreground="#4B5563" FontSize="13"/>
                                </StackPanel>

                                <Separator BorderBrush="#E5E7EB" BorderThickness="0.5"/>

                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="💻 Geliştirici" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF"/>
                                        <TextBlock Text="Arda Önder" FontSize="14" FontWeight="SemiBold" Foreground="#1F2937"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#F3F4F6" CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                                        <TextBlock Text="v1.0.0-stable" FontSize="11" FontWeight="Bold" Foreground="#4B5563"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>