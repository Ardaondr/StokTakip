<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StokTakip.ExcelImportWindow"
        Title="Excel'den İlaç İçe Aktar" Width="580" Height="460"
        MinWidth="520" MinHeight="420">
    <Grid Margin="14" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto">

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Kendi hazırladığınız stok Excel dosyasını (.xlsx) seçin. İlk satır başlık kabul edilir. İlaç zaten sistemde kayıtlıysa miktarı Excel'deki değerle güncellenir, yoksa yeni kayıt olarak eklenir."/>

        <!-- Dosya seçimi -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <Button x:Name="SelectFileButton" Content="Excel Dosyası Seç..." Click="SelectFileButton_Click"/>
            <TextBlock x:Name="FileNameText" VerticalAlignment="Center" Text="Dosya seçilmedi" FontStyle="Italic"/>
        </StackPanel>

        <!-- Zorunlu + opsiyonel sütun eşleştirme -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,10">
            <StackPanel Orientation="Vertical" Width="260" Margin="0,0,16,0">
                <TextBlock Text="İlaç (Ürün) Adı Sütunu *"/>
                <ComboBox x:Name="ProductColumnCombo" Width="260" SelectionChanged="ColumnCombo_SelectionChanged"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Width="260">
                <TextBlock Text="Miktar Sütunu (opsiyonel, boşsa 0 girilir)"/>
                <ComboBox x:Name="QuantityColumnCombo" Width="260" SelectionChanged="ColumnCombo_SelectionChanged"/>
            </StackPanel>
        </WrapPanel>

        <TextBlock Grid.Row="4" Text="Önizleme (ilk 5 satır):" FontWeight="Bold" Margin="0,0,0,4"/>

        <ScrollViewer Grid.Row="5" Margin="0,0,0,10">
            <TextBlock x:Name="PreviewText" TextWrapping="Wrap" FontFamily="Consolas,Menlo,monospace"/>
        </ScrollViewer>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8">
            <Button x:Name="ImportButton" Content="İçe Aktar" Click="ImportButton_Click" IsEnabled="False"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>